{
  "manifest_version": 3,
  "name": "Flow",
  "version": "1.0",
  "description": "Snapshot browser tabs for Flow.",
  "permissions": ["tabs", "alarms"],
  "host_permissions": ["http://localhost:3000/*"],
  "action": {
    "default_title": "Snapshot Tabs"
  },
  "background": {
    "service_worker": "background.js"
  }
}